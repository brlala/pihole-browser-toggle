{
  "manifest_version": 3,
  "name": "Pi-hole Toggle",
  "version": "1.0.0",
  "description": "Temporarily disable Pi-hole blocking from the toolbar (Pi-hole v6).",
  "permissions": ["storage", "activeTab", "tabs"],
  "optional_host_permissions": ["*://*/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Pi-hole Toggle",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js"
  }
}
